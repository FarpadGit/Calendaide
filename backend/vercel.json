{
    "builds": [
      {
        "src": "main.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "main.py",
        "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "https://calendaide.vercel.app"},
          { "key": "Access-Control-Allow-Credentials", "value": "true" }
        ]
      }
    ]
  }